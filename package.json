{
    "name": "enterprise-camp",
    "version": "1.0.0",
    "description": "Enterprise Request Management System",
    "main": "src/server.js",
    "scripts": {
        "dev": "nodemon src/server.js",
        "start": "node src/server.js",
        "test": "jest",
        "test:unit": "jest test/unitTest --verbose",
        "test:coverage": "jest test/unitTest --coverage",
        "test:integration": "jest test/integrationTest --verbose --forceExit",
        "test:all": "jest --verbose --forceExit",
        "db:push": "prisma db push",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:studio": "prisma studio"
    },
    "jest": {
        "testEnvironment": "node",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/server.js",
            "!src/db/**"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/client": "^6.4.1",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "nodemon": "^3.1.9",
        "prisma": "^6.4.1",
        "supertest": "^7.2.2"
    }
}